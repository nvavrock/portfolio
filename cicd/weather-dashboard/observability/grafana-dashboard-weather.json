      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(weather_http_request_duration_seconds_bucket[5m])))",
