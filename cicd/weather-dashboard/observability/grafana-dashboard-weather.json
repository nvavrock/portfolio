          "legendFormat": "{{handler}} {{code}}",
          "refId": "A"
        }
      ],
      "title": "HTTP request rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
